{
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:ssr": "vite build && vite build --ssr",
    "dev": "concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"vite\" --names=server,queue,logs,vite --kill-others",
    "format": "prettier --write . && ./vendor/bin/pint",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "types:check": "tsc --noEmit"
  },

  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@inertiajs/react": "^3.0.0",
    "@inertiajs/vite": "^3.0.0",
    "@laravel/vite-plugin-wayfinder": "^0.1.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^22.13.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.0.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^15.14.0",
    "laravel-vite-plugin": "^3.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.23.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.1"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "printWidth": 120,
    "trailingComma": "es5",
    "tailwindFunctions": [
      "clsx",
      "tw"
    ],
    "plugins": [
      "prettier-plugin-organize-imports",
      "prettier-plugin-tailwindcss"
    ]
  }
}
